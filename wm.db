    result(Austria, Jordan)


CREATE TABLE team (
    id INT
    team_name_home TEXT
    team_name_guests TEXT
    game_id INT

    PRIMARY KEY (id)
    FOREIGN KEY(game_id) REFERENCES game(id)

)


CREATE TABLE game(
    id INT
    result TEXT
    
    team_id INT
    PRIMARY KEY(id)
    FOREIGN KEY(team_id) REFERENCES team(id)
)

