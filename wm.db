def result(conn, team1, team2):
    sql = """
        SELECT team_name
        FROM team t
        INNER JOIN game g
        ON t.game_id = g.id
        WHERE result = ?
    """

conn.execute(sql,(team_name_home, team_name_guests)).fetchone

with sqlite3 connect("dbi.sql") as conn:
    result(conn, Austria, Jordan)


CREATE TABLE team (
    team_home text
    team_guests text
    
    game_id INT

    PRIMARY KEY (team_home, team_guests)
    FOREIGN KEY(game_id) REFERENCES game(id)

)


CREATE TABLE game(
    id INT
    result TEXT
    
    team_home text
    team_guests text
    PRIMARY KEY(id)
    FOREIGN KEY(team_home) REFERENCES team(team_home)
    FOREIGN KEY(team_guests) REFERENCES team(team_guests)
)

